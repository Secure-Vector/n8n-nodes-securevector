{
  "name": "@securevector/n8n-nodes-securevector",
  "version": "0.2.1",
  "description": "SecureVector AI security for n8n: prompt and output scanning, tool-call audit, cost tracking, budget enforcement. Cloud API + optional Local App transport. See LICENSE.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "securevector",
    "security",
    "ai-security",
    "llm-security",
    "prompt-injection",
    "threat-detection",
    "tool-audit",
    "cost-tracking"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Secure-Vector/n8n-nodes-securevector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Secure-Vector/n8n-nodes-securevector.git"
  },
  "bugs": {
    "url": "https://github.com/Secure-Vector/n8n-nodes-securevector/issues"
  },
  "author": {
    "name": "SecureVector",
    "email": "support@securevector.io"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/post-build.js",
    "dev": "tsc --watch",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run build",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SecureVectorApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SecureVector/SecureVector.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-n8n-nodes-base": "^1.16.4",
    "jest": "^29.7.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.8.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
