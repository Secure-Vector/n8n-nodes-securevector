# @n8n/node-cli@0.28.0 declares peer eslint >= 9, but eslint-plugin-n8n-nodes-base
# and our @typescript-eslint/* v6 chain still require eslint v8. Forcing peer-dep
# resolution to legacy lets both coexist; nothing in our build path actually
# invokes the n8n-cli's own eslint config (we use our own).
#
# Required for `npm ci` in CI to succeed; `npm install` flags don't inherit
# in CI when only npm ci runs.
legacy-peer-deps=true
